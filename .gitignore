# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# ── Build / packaging ────────────────────────────────────────────────────────
build/
dist/
*.egg-info/
*.egg
MANIFEST
.eggs/

# PyInstaller
# (keep packaging/*.spec via the negation rule below)
*.spec
!packaging/*.spec

# ── AppImage artifacts ───────────────────────────────────────────────────────
AppDir/
*.AppImage
*.AppImage.zsync

# Generated icon (produced at build time by packaging/generate_icon.py)
appimage/focus-mode-app.png

# ── Virtual environments ─────────────────────────────────────────────────────
.venv/
.venv-*/
venv/
.venv_new/
ENV/

# ── Runtime data & logs ──────────────────────────────────────────────────────
# Dev-mode data written next to the package (XDG paths used when frozen)
data/
focus_mode_app/data/
focus_mode_app/logs/
*.log
app.log

# ── Tests & coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# ── Linters / formatters ─────────────────────────────────────────────────────
.ruff_cache/
.mypy_cache/

# ── IDEs ─────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Debug / investigation scripts ────────────────────────────────────────────
test_*.py
patch_*.py
build_*/
dist_*/

# ── Misc ─────────────────────────────────────────────────────────────────────
.env
.envrc
pip-log.txt
