#!/bin/bash
# AppRun — entry point for the Focus Mode App AppImage.

SELF="$(readlink -f "$0")"
HERE="${SELF%/*}"

# Point Tcl/Tk to the bundled libraries so ttkbootstrap's msgcat loads.
# PyInstaller 6.x bundles Tcl/Tk scripts in _tcl_data/_tk_data (newer) or
# tcl8.6/tk8.6 (older layouts) — check all known locations.
if [ -d "$HERE/_internal/_tcl_data" ]; then
    export TCL_LIBRARY="$HERE/_internal/_tcl_data"
    export TK_LIBRARY="$HERE/_internal/_tk_data"
elif [ -d "$HERE/_internal/tcl8.6" ]; then
    export TCL_LIBRARY="$HERE/_internal/tcl8.6"
    export TK_LIBRARY="$HERE/_internal/tk8.6"
elif [ -d "$HERE/tcl8.6" ]; then
    export TCL_LIBRARY="$HERE/tcl8.6"
    export TK_LIBRARY="$HERE/tk8.6"
fi

# Prefer native Wayland for the Qt tray icon; Tkinter uses XWayland internally.
if [ -z "$QT_QPA_PLATFORM" ]; then
    if [ "$XDG_SESSION_TYPE" = "wayland" ]; then
        export QT_QPA_PLATFORM=wayland
    fi
fi

exec "$HERE/focus-mode-app" "$@"
